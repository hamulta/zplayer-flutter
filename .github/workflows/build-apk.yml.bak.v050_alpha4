name: Build APK

on:
  push:
    branches:
      - main
      - feature/background-playback
  workflow_dispatch:

permissions:
  contents: read

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Setup Java
        uses: actions/setup-java@v4
        with:
          distribution: temurin
          java-version: "17"

      - name: Setup Flutter
        uses: subosito/flutter-action@v2
        with:
          channel: stable
          cache: true

      - name: Show Flutter version
        run: flutter --version

      - name: Generate Android project files
        run: |
          flutter create --platforms=android --project-name zplayer_offline .
          rm -rf test

      - name: Inject native Android MediaSession engine
        run: |
          python3 <<'PY'
          from pathlib import Path
          import base64
          import re

          package_path = Path("android/app/src/main/kotlin/com/example/zplayer_offline")
          package_path.mkdir(parents=True, exist_ok=True)

          main_activity = base64.b64decode("").decode()
          media_service = base64.b64decode("").decode()

          (package_path / "MainActivity.kt").write_text(main_activity)
          (package_path / "RakyzuMediaService.kt").write_text(media_service)

          manifest = Path("android/app/src/main/AndroidManifest.xml")
          text = manifest.read_text()

          if "xmlns:tools" not in text:
              text = text.replace(
                  '<manifest xmlns:android="http://schemas.android.com/apk/res/android">',
                  '<manifest xmlns:android="http://schemas.android.com/apk/res/android" xmlns:tools="http://schemas.android.com/tools">',
                  1,
              )

          permissions = [
              '<uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />',
              '<uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />',
              '<uses-permission android:name="android.permission.POST_NOTIFICATIONS" />',
              '<uses-permission android:name="android.permission.WAKE_LOCK" />',
              '<uses-permission android:name="android.permission.FOREGROUND_SERVICE" />',
              '<uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />',
          ]

          for permission in permissions:
              key = re.search(r'android:name="([^"]+)"', permission).group(1)
              if key not in text:
                  text = text.replace("    <application", f"    {permission}\n\n    <application", 1)

          text = re.sub(r'android:label="[^"]+"', 'android:label="Rakyzu Music Player"', text, count=1)

          text = re.sub(
              r'android:name="[^"]*AudioServiceActivity"',
              'android:name=".MainActivity"',
              text,
              count=1,
          )

          if "RakyzuMediaService" not in text:
              service_block = '''
          <service
              android:name=".RakyzuMediaService"
              android:exported="false"
              android:foregroundServiceType="mediaPlayback" />
          '''
              text = text.replace("    </application>", service_block + "\n    </application>", 1)

          manifest.write_text(text)
          print(text)

          gradle = Path("android/app/build.gradle")
          gradle_kts = Path("android/app/build.gradle.kts")

          if gradle.exists():
              g = gradle.read_text()

              deps = [
                  'implementation "androidx.core:core-ktx:1.13.1"',
                  'implementation "androidx.media:media:1.7.0"',
              ]

              if "dependencies {" not in g:
                  g += "\n\ndependencies {\n}\n"

              for dep in deps:
                  if dep not in g:
                      g = g.replace("dependencies {", "dependencies {\n    " + dep, 1)

              g = re.sub(r'compileSdk\\s*=?\\s*\\d+', 'compileSdk 35', g)
              g = re.sub(r'compileSdkVersion\\s+\\d+', 'compileSdkVersion 35', g)

              gradle.write_text(g)
              print("Patched Groovy Gradle:", gradle)
              print(g)

          elif gradle_kts.exists():
              g = gradle_kts.read_text()

              deps = [
                  'implementation("androidx.core:core-ktx:1.13.1")',
                  'implementation("androidx.media:media:1.7.0")',
              ]

              if "dependencies {" not in g:
                  g += "\n\ndependencies {\n}\n"

              for dep in deps:
                  if dep not in g:
                      g = g.replace("dependencies {", "dependencies {\n    " + dep, 1)

              g = re.sub(r'compileSdk\\s*=\\s*\\d+', 'compileSdk = 35', g)
              g = re.sub(r'compileSdkVersion\\(\\d+\\)', 'compileSdkVersion(35)', g)

              gradle_kts.write_text(g)
              print("Patched Kotlin Gradle:", gradle_kts)
              print(g)

          else:
              raise SystemExit("Neither android/app/build.gradle nor android/app/build.gradle.kts exists")
          PY

      - name: Fix native ContextCompat import
        run: |
          python3 <<'PY2'
          from pathlib import Path

          fixed = False
          for file in Path("android/app/src/main/kotlin").rglob("RakyzuMediaService.kt"):
              text = file.read_text()
              text = text.replace(
                  "import androidx.core.content.ContextCompat",
                  "import androidx.core.content.ContextCompat",
              )
              file.write_text(text)
              print("Fixed:", file)
              print(text)
              fixed = True

          if not fixed:
              raise SystemExit("RakyzuMediaService.kt not found")
          PY2

      - name: Force Android app display name
        run: |
          python3 <<'PY'
          from pathlib import Path
          import re

          manifest = Path("android/app/src/main/AndroidManifest.xml")
          text = manifest.read_text()

          if 'android:label="' in text:
              text = re.sub(
                  r'android:label="[^"]+"',
                  'android:label="Rakyzu Music Player"',
                  text,
                  count=1,
              )
          else:
              text = text.replace(
                  "    <application",
                  '    <application android:label="Rakyzu Music Player"',
                  1,
              )

          manifest.write_text(text)
          print(text)
          PY

      - name: Get dependencies
        run: flutter pub get

      - name: Patch on_audio_query Android Gradle compatibility
        run: |
          python3 <<'PY'
          from pathlib import Path
          import re

          files = list(Path.home().glob(".pub-cache/hosted/pub.dev/on_audio_query_android-*/android/build.gradle"))

          if not files:
              raise SystemExit("on_audio_query_android android/build.gradle not found")

          gradle = files[0]
          text = gradle.read_text()

          namespace = "com.lucasjosino.on_audio_query"
          manifest = gradle.parent / "src" / "main" / "AndroidManifest.xml"

          if manifest.exists():
              manifest_text = manifest.read_text()
              match = re.search(r'package="([^"]+)"', manifest_text)
              if match:
                  namespace = match.group(1)

          if "namespace " not in text and "namespace=" not in text:
              text = text.replace("android {", "android {\\n    namespace '" + namespace + "'", 1)

          text = re.sub(r'compileSdkVersion\s+\d+', 'compileSdkVersion 35', text)
          text = re.sub(r'compileSdk\s*=?\s*\d+', 'compileSdk 35', text)

          if "compileSdk" not in text:
              text = text.replace("android {", "android {\n    compileSdk 35", 1)

          if "compileOptions" not in text:
              text = text.replace(
                  "android {",
                  '''android {
              compileOptions {
                  sourceCompatibility JavaVersion.VERSION_17
                  targetCompatibility JavaVersion.VERSION_17
              }''',
                  1
              )

          if "jvmTarget" not in text:
              text += '''

          tasks.withType(org.jetbrains.kotlin.gradle.tasks.KotlinCompile).configureEach {
              kotlinOptions {
                  jvmTarget = "17"
              }
          }
          '''

          gradle.write_text(text)
          print("Patched Gradle file:", gradle)
          print(text)
          PY

      - name: Patch app Android compileSdk
        run: |
          python3 <<'PY'
          from pathlib import Path
          import re

          for file in [
              Path("android/app/build.gradle"),
              Path("android/build.gradle"),
          ]:
              if not file.exists():
                  continue

              text = file.read_text()
              text = re.sub(r'compileSdk\s*=?\s*\d+', 'compileSdk 35', text)
              text = re.sub(r'compileSdkVersion\s+\d+', 'compileSdkVersion 35', text)
              file.write_text(text)
              print("Checked:", file)
          PY

      - name: Generate launcher icons
        run: dart run flutter_launcher_icons

      - name: Analyze Dart
        run: |
          rm -rf test
          flutter analyze lib --no-fatal-infos --no-fatal-warnings

      - name: Build debug APK
        run: flutter build apk --debug

      - name: Upload APK artifact
        uses: actions/upload-artifact@v4
        with:
          name: Rakyzu-Music-Player-debug-apk
          path: build/app/outputs/flutter-apk/app-debug.apk
          if-no-files-found: error
